{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FicWriter",
  "version": "0.1.4",
  "identifier": "com.admin.ficwriter",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
"app": {
  "windows": [
    { 
      "label": "main",
      "title": "FicWriter",
      "width": 1400,
      "height": 900,
      "minWidth": 1100,
      "minHeight": 720,
      "resizable": true,
      "fullscreen": false,
      "maximized": true,
      "decorations": false
      }
  ],
  "security": {
    "csp": null,
    "assetProtocol": {
      "enable": true,
      "scope": ["$APPDATA/**"]
    }
  }
},
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "Copyright © 2026 Herasymova V.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
